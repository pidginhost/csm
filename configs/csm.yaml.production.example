# Continuous Security Monitor -- production reference config
#
# Drop-in profile for a cPanel/WHM mail host running CSM in
# enforcing mode (live IP blocks, live spray suppression, live
# auto-response). Copy to /opt/csm/csm.yaml, edit every
# SET_* placeholder, run `csm rehash` then
# `systemctl restart csm`.
#
# Companion to the shipped default at
# /usr/share/csm/csm.yaml.default. Comments only call out the
# values that differ from the shipped default or that operators
# routinely tune in production. Read the default for the full
# field list.

hostname: "SET_FQDN_HERE"

alerts:
  email:
    enabled: true
    to:
      - "SET_ONCALL_EMAIL_HERE"
    from: "csm@SET_FQDN_HERE"
    smtp: "localhost:25"
    # Production noise filters. Drop alerts that are either
    # already actioned by other channels (cpanel_login, perf_*)
    # or known-fragile (challenge_route, dns_zone_change).
    # Re-enable individually when you want a particular check
    # paging on this host.
    disabled_checks:
      - email_spam_outbreak
      - email_compromised_account
      - perf_memory
      - perf_php_processes
      - api_auth_failure_realtime
      - challenge_route
      - cpanel_login_realtime
      - cpanel_login
      - dns_zone_change
  webhook:
    enabled: false
    url: ""
    type: "slack"
  heartbeat:
    enabled: false
    url: ""
  max_per_hour: 100

webui:
  enabled: true
  listen: "0.0.0.0:9443"
  auth_token: ""
  tokens:
    - name: "admin"
      token: "SET_WEBUI_ADMIN_TOKEN_HERE"
      scope: "admin"
  tls_cert: ""
  tls_key: ""
  ui_dir: "/opt/csm/ui"

challenge:
  listen_addr: "0.0.0.0"
  listen_port: 8439
  tls_cert: "/etc/letsencrypt/live/SET_FQDN_HERE/fullchain.pem"
  tls_key: "/etc/letsencrypt/live/SET_FQDN_HERE/privkey.pem"
  public_url: "https://SET_FQDN_HERE:8439/challenge"
  port_gate:
    enabled: true

integrity:
  binary_hash: ""
  config_hash: ""
  immutable: true

signatures:
  rules_dir: "/opt/csm/rules"
  auto_update: true
  update_url: ""
  signing_key: ""
  yara_forge:
    enabled: false
    tier: "core"
    update_interval: "168h"
    download_url: ""

reputation:
  # Async PTR + forward-A verification for claimed bot User-Agents.
  # Static ranges are trusted first. DNS cache misses and transient
  # resolver failures fail open; confirmed PTR/forward-A mismatches
  # emit http_ua_spoof on a later scan that still sees the request.
  # Set false only if outbound DNS is unavailable and you accept
  # trusting UA strings.
  bot_verify_enabled: true
  # Optional operator-defined crawlers. Each entry needs a stable UA
  # substring plus one verification method: an rdns_suffix that
  # forward-confirms the source IP (SEO/search crawlers), or ip_ranges of
  # published CIDRs (AI agents like PerplexityBot/GPTBot that have no
  # crawler rDNS). Shared-hosting suffixes and over-broad/non-public
  # ranges are rejected.
  verified_bots: []
  # verified_bots:
  #   - name: "seranking"
  #     ua_substrings: ["serankingbacklinksbot"]
  #     rdns_suffixes: ["seranking.com"]
  #   - name: "perplexitybot"
  #     ua_substrings: ["perplexitybot"]
  #     ip_ranges: ["18.97.9.96/29", "18.97.1.228/30"]
  # Auto-update of built-in AI-crawler IP ranges (OpenAI, Perplexity). These
  # ship as a snapshot and refresh from the vendor endpoints on a schedule.
  # Outbound HTTPS; set auto_update: false to use the snapshot only. Changes
  # require a daemon restart because the updater is started once at boot.
  bot_ranges:
    auto_update: true
    update_interval: "24h"

thresholds:
  mail_queue_warn: 500
  mail_queue_crit: 2000
  state_expiry_hours: 24
  deep_scan_interval_min: 60
  wp_core_check_interval_min: 60
  webshell_scan_interval_min: 30
  filesystem_scan_interval_min: 30
  multi_ip_login_threshold: 3
  multi_ip_login_window_min: 60
  cred_stuffing_distinct_accounts: 5
  brute_force_window: 5000
  domlog_max_files: 500
  domlog_tail_lines: 500
  domlog_max_age_min: 30
  mail_log_tail_lines: 500
  syslog_messages_tail_lines: 200
  account_scan_max_files: 10000
  # crontab_base64_blob_max_bytes caps the encoded length of a single
  # base64 candidate before decoding inside the crontab deep-scan
  # decoder. Must be a multiple of 4. Raise on hosts where
  # csm_checks_crontab_base64_truncated_total shows recurring
  # truncation and the source is not an attacker padding past the cap.
  crontab_base64_blob_max_bytes: 16384
  # HTTP request flood: per-source-IP request count inside the window
  # that emits http_request_flood. 0 disables the detector. Sample
  # local baseline before raising; busy WP shops can see 200-600 req
  # per IP per 5m at peak, and carrier NAT / CDN exits skew higher.
  http_flood_threshold: 0
  http_flood_window_min: 5
  # User-Agent spoof: per-IP per-window count for non-browser UA kinds
  # (scripting, headless, empty) that emits http_ua_spoof. Default 30.
  # Claimed bot UAs with confirmed PTR/forward-A mismatches fire
  # regardless of this threshold.
  http_ua_spoof_threshold: 30
  # Distributed HTTP attack: distinct already-abusive source IPs hitting
  # one vhost in a scan window before the per-vhost rollup fires.
  # 0 disables the rollup.
  http_distributed_min_ips: 10
  # URL scanner profile: source IPs whose in-window traffic is almost
  # entirely probe-error responses (default 404/403) spread across many
  # distinct paths -- random-URL enumeration hunting for downloadable
  # files, backups, and dormant shells. min_requests 0 disables the
  # detector; 30 is a safe starting volume gate. 301 is deliberately
  # not in the default status set: http->https redirects and site
  # migrations make legitimate traffic 301-heavy.
  http_scanner_min_requests: 0
  http_scanner_error_pct: 90
  http_scanner_min_distinct_paths: 10
  http_scanner_status_codes: [404, 403]
  # Opt-in UA classes. These match many legitimate monitoring agents;
  # leave disabled unless the noise floor is known.
  http_ua_scripting_enabled: false
  http_ua_headless_enabled: false
  http_ua_empty_enabled: false
  # Mail brute / spray detector tuning. Defaults are
  # cPanel-mail-host-tested; lower the bruteforce_threshold for
  # smaller hosts, raise it for hosts behind shared NAT.
  smtp_bruteforce_threshold: 5
  smtp_bruteforce_window_min: 10
  smtp_bruteforce_suppress_min: 60
  smtp_bruteforce_subnet_threshold: 8
  smtp_account_spray_threshold: 12
  smtp_bruteforce_max_tracked: 20000
  mail_bruteforce_threshold: 5
  mail_bruteforce_window_min: 10
  mail_bruteforce_suppress_min: 60
  mail_bruteforce_subnet_threshold: 8
  mail_account_spray_threshold: 12
  mail_bruteforce_max_tracked: 20000
  # ModSecurity escalation. Defaults of 3 hits / 10m miss low-and-slow
  # scanners that spread denies across hours. Raising the window to 4h
  # while keeping hits at 3 catches paced attackers without triggering
  # on isolated false-positives.
  modsec_escalation_hits: 3
  modsec_escalation_window_min: 240

state_path: "/opt/csm/state"

# Management network, monitoring probes, phpanel agent, and
# anything else you do NOT want CSM to ever firewall. Hostnames
# resolve on the DynDNS schedule and emit
# `infra_ips_unresolvable` if they go dark.
infra_ips:
  - "SET_MGMT_CIDR_HERE"
  # - "10.0.0.0/8"
  # - "phpanel.example.com"

suppressions:
  upcp_window_start: "00:30"
  upcp_window_end: "02:00"
  known_api_tokens: []
  ignore_paths:
    - "*/imunify-security/*"
    - "*/cache/*"
    - "*/vendor/*"
  suppress_webmail_alerts: true
  suppress_cpanel_login_alerts: false
  suppress_blocked_alerts: true
  # ISO country codes whose traffic is downgraded from auto-block
  # to alert-only. Keep your operator country here so a misclick
  # from the office never locks you out.
  trusted_countries:
    - "RO"

auto_response:
  enabled: true
  dry_run: false              # FLIP AFTER VALIDATION
  kill_processes: true
  quarantine_files: true
  block_ips: true
  block_expiry: "24h"
  max_blocks_per_hour: 50
  enforce_permissions: true
  block_cpanel_logins: true
  # http_scanner_action: response for http_scanner_profile findings.
  # "challenge" (default) routes the IP to the PoW challenge when the
  # challenge subsystem is enabled, falling through to a block when it
  # is not; "block" always hard-blocks.
  http_scanner_action: "challenge"
  netblock: false
  netblock_threshold: 3
  permblock: false
  permblock_count: 4
  permblock_interval: "24h"
  mail_auth_recovery:
    restart_enabled: false
    down_grace: "10m"
    max_restarts_per_hour: 3
    restart_command: "/usr/local/cpanel/scripts/restartsrv_dovecot"
  verdict_callback:
    enabled: false
    url: ""
    hmac_secret: ""
    hmac_secret_env: ""
    allow_unsigned: false
    require_response_signature: true
    timeout_sec: 2

firewall:
  enabled: true
  # SSH (port 22) is intentionally absent. cPanel hosts typically
  # move sshd to 2087 or a custom port. Uncomment the right entry
  # before enabling or you will lock yourself out.
  tcp_in:
    - 20
    - 21
    # - 22
    - 25
    - 26
    - 53
    - 80
    - 110
    - 143
    - 443
    - 465
    - 587
    - 853
    - 993
    - 995
    - 2077
    - 2078
    - 2079
    - 2080
    - 2082
    - 2083
    - 2091
    - 2095
    - 2096
  tcp_out:
    - 20
    - 21
    - 25
    - 26
    - 37
    - 43
    - 53
    - 80
    - 110
    - 113
    - 443
    - 465
    - 587
    - 853
    - 873
    - 993
    - 995
    - 2082
    - 2083
    - 2086
    - 2087
    - 2089
    - 2195
    - 2325
    - 2703
  udp_in:
    - 53
    - 443
    - 853
  udp_out:
    - 53
    - 113
    - 123
    - 443
    - 853
    - 873
    - 6277
    - 24441
  restricted_tcp:
    - 2086
    - 2087
    - 2325
    - 9443
  passive_ftp_start: 49152
  passive_ftp_end: 65534
  # 200/min and conn_limit 400 are CGNAT-tolerant. Lower if your
  # customer base is not behind shared NAT and you want tighter
  # caps.
  conn_rate_limit: 200
  syn_flood_protection: true
  conn_limit: 400
  port_flood:
    - port: 25
      proto: tcp
      hits: 600
      seconds: 300
    - port: 465
      proto: tcp
      hits: 600
      seconds: 300
    - port: 587
      proto: tcp
      hits: 600
      seconds: 300
  udp_flood: true
  udp_flood_rate: 100
  udp_flood_burst: 500
  drop_nolog:
    - 23
    - 67
    - 68
    - 111
    - 113
    - 135
    - 136
    - 137
    - 138
    - 139
    - 445
    - 500
    - 513
    - 520
  deny_ip_limit: 3000
  deny_temp_ip_limit: 500
  smtp_block: false
  smtp_allow_users:
    - cpanel
    - mailman
  smtp_ports:
    - 25
    - 465
    - 587
  log_dropped: true
  log_rate: 5

c2_blocklist: []
backdoor_ports:
  - 4444
  - 5555
  - 55553
  - 55555
  - 31337

retention:
  enabled: true
  findings_days: 90
  history_days: 30
  reputation_days: 180
  sweep_interval: 24h
  compact_min_size_mb: 128
  compact_fill_ratio: 0.5

updates:
  check_enabled: true
  interval: "24h"
  package_name: "csm"

sentry:
  enabled: false
  dsn: ""
  environment: "production"
  sample_rate: 1.0
  debug: false

incidents:
  auto_close:
    enabled: true
    dry_run: false
    by_kind:
      mailbox_takeover: 24h
      mailbox_bruteforce: 24h
      credential_spray: 24h
      web_attack: 24h
      web_account_compromise: 168h

  # Credential-spray super-incident. Production tuning:
  # block_at_severity=high so the firewall hand-off fires on the
  # first sustained burst (distinct_mailboxes before the source IP
  # is idle for more than the merge window). The "critical" tier can
  # miss low-and-slow attackers that stay below severity_escalate_at
  # before each idle reset. See docs/incidents for the full trade-off.
  spray_suppression:
    enabled: true
    dry_run: false              # FLIP AFTER 24H DRY-RUN VALIDATION
    distinct_mailboxes: 10
    severity_escalate_at: 20
    per_check:
      - email_auth_failure_realtime
      - pam_auth_failure
      - ssh_bruteforce
    max_tracked_ips: 20000
    block_at_severity: "high"

  # Generic incident-driven auto-block. Catches paced attackers that
  # never trip per-detector windows (e.g. modsec hits spread across
  # hours). Blocks at CRITICAL because the correlator only promotes an
  # incident to CRITICAL on strong signals (modsec escalation, account
  # compromise, cloud-relay abuse). credential_spray is excluded -- the
  # spray_suppression hand-off owns it.
  auto_block:
    enabled: true
    block_at_severity: "critical"
    kinds: []
